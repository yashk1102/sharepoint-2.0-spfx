{
  "$schema": "https://developer.microsoft.com/json-schemas/spfx-build/config.2.0.schema.json",
  "version": "2.0",
  "bundles": {
    "rapid-city-homepage-web-part": {
      "components": [
        {
          "entrypoint": "./lib/webparts/rapidCityHomepage/RapidCityHomepageWebPart.js",
